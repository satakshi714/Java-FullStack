<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.0"
    xmlns="http://java.sun.com/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://java.sun.com/xml/ns/persistence
                        http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd">

    <persistence-unit name="crmPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.capg.assessment.entity.Address</class>
        <class>com.capg.assessment.entity.Customer</class>
        <class>com.capg.assessment.entity.Lead</class>
        <class>com.capg.assessment.entity.SalesEmployee</class>
        <class>com.capg.assessment.entity.Product</class>
        <class>com.capg.assessment.entity.Order</class>
        <class>com.capg.assessment.entity.SupportTicket</class>

        <properties>
            <property name="javax.persistence.jdbc.driver" value="oracle.jdbc.driver.OracleDriver"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:oracle:thin:@localhost:1521:xe"/>
            <property name="javax.persistence.jdbc.user" value="shinchan"/>
            <property name="javax.persistence.jdbc.password" value="shinchan"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.Oracle10gDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>

    </persistence-unit>
</persistence>